<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # 1. अगर रिक्वेस्ट /uploads के लिए है, तो उसे यहीं रोक दें 
  # ताकि वह नीचे वाले React/Index रूल्स तक न पहुंचे
  RewriteCond %{REQUEST_URI} ^/uploads [NC]
  RewriteRule ^ - [L]

  # 2. React Routing
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
